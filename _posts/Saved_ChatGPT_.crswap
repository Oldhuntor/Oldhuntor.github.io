# Re-importing necessary libraries and redefining variables
import numpy as np
from scipy.stats import binom

# Parameters
short_size = 10  # Size of the short period
long_size = 5    # Size of the long period
theta_space = np.linspace(0, 1, 11)  # Possible values for theta (market up probability)

# Observed data
long_up = 2  # Number of ups in the long period
short_up = 8  # Number of ups in the short period

# Calculate priors based on long term data using binomial distribution
priors = binom.pmf(long_up, long_size, theta_space)

# Normalize the priors to ensure their sum equals 1
normalized_priors = priors / np.sum(priors)

# Likelihood for the short period data given different thetas
likelihoods = binom.pmf(short_up, short_size, theta_space)

# Calculate the evidence (normalizing constant) with normalized priors
normalized_evidence = np.sum(likelihoods * normalized_priors)

# Calculate the posterior distribution with normalized priors
normalized_posterior = (likelihoods * normalized_priors) / normalized_evidence

# Finding the theta value corresponding to the maximum posterior probability
max_posterior_value = normalized_posterior.max()
max_posterior_theta = theta_space[np.argmax(normalized_posterior)]

max_posterior_value, max_posterior_theta

