<math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi>P</mi><mo stretchy="false">(</mo><mi>C</mi><mo stretchy="false">)</mo><mo>=</mo><mi>P</mi><mo stretchy="false">(</mo><mi>C</mi><mi mathvariant="normal">∣</mi><mi>A</mi><mo stretchy="false">)</mo><mo>⋅</mo><mi>P</mi><mo stretchy="false">(</mo><mi>A</mi><mo stretchy="false">)</mo><mo>+</mo><mi>P</mi><mo stretchy="false">(</mo><mi>C</mi><mi mathvariant="normal">∣</mi><mi>B</mi><mo stretchy="false">)</mo><mo>⋅</mo><mi>P</mi><mo stretchy="false">(</mo><mi>B</mi><mo stretchy="false">)</mo></mrow><annotation encoding="application/x-tex">P(C) = P(C|A) \cdot P(A) + P(C|B) \cdot P(B)</annotation></semantics></math><span class="katex-html" aria-hidden="true"><span class="strut" style="height: 1em; vertical-align: -0.25em;"><span class="mord mathnormal" style="margin-right: 0.13889em;">P(<span class="mord mathnormal" style="margin-right: 0.07153em;">C)<span class="mspace" style="margin-right: 0.2778em;">=<span class="mspace" style="margin-right: 0.2778em;"><span class="strut" style="height: 1em; vertical-align: -0.25em;"><span class="mord mathnormal" style="margin-right: 0.13889em;">P(<span class="mord mathnormal" style="margin-right: 0.07153em;">C∣A)<span class="mspace" style="margin-right: 0.2222em;">⋅<span class="mspace" style="margin-right: 0.2222em;"><span class="strut" style="height: 1em; vertical-align: -0.25em;"><span class="mord mathnormal" style="margin-right: 0.13889em;">P(A)<span class="mspace" style="margin-right: 0.2222em;">+<span class="mspace" style="margin-right: 0.2222em;"><span class="strut" style="height: 1em; vertical-align: -0.25em;"><span class="mord mathnormal" style="margin-right: 0.13889em;">P(<span class="mord mathnormal" style="margin-right: 0.07153em;">C∣<span class="mord mathnormal" style="margin-right: 0.05017em;">B)<span class="mspace" style="margin-right: 0.2222em;">⋅<span class="mspace" style="margin-right: 0.2222em;"><span class="strut" style="height: 1em; vertical-align: -0